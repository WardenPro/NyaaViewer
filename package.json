{
  "name": "nyaa-viewer",
  "version": "1.3.9",
  "description": "Nyaa.si anime torrent viewer with AllDebrid streaming",
  "author": "WardenPro",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run download-binaries && tsc && vite build && electron-builder",
    "build:win": "npm run download-binaries && tsc && vite build && electron-builder --win --publish never",
    "build:mac": "npm run download-binaries && tsc && vite build && electron-builder --mac --publish never",
    "build:linux": "tsc && vite build && electron-builder --linux --publish never",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "download-binaries": "node scripts/download-binaries.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.2.0",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^4.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
